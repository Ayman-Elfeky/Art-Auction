{
  "version": 1,
  "modules": [
    {
      "name": "Admin",
      "description": "Admin review and approval endpoints",
      "prefix": "/api/admin",
      "actions": [
        {
          "name": "GetPendingArtists",
          "description": "Get all artists waiting for approval",
          "method": "GET",
          "path": "/artists/pending",
          "input": "",
          "output": "PendingArtist",
          "outputArray": true,
          "middleware": [
            "RequireAdmin"
          ]
        },
        {
          "name": "ApproveArtist",
          "description": "Approve an artist account",
          "method": "PUT",
          "path": "/artists/:id/approve",
          "input": "",
          "output": "AdminActionMessage",
          "middleware": [
            "RequireAdmin"
          ]
        },
        {
          "name": "RejectArtist",
          "description": "Reject an artist account",
          "method": "PUT",
          "path": "/artists/:id/reject",
          "input": "",
          "output": "AdminActionMessage",
          "middleware": [
            "RequireAdmin"
          ]
        },
        {
          "name": "GetPendingArtworks",
          "description": "Get all artworks waiting for approval",
          "method": "GET",
          "path": "/artworks/pending",
          "input": "",
          "output": "PendingArtwork",
          "outputArray": true,
          "middleware": [
            "RequireAdmin"
          ]
        },
        {
          "name": "ApproveArtwork",
          "description": "Approve an artwork",
          "method": "PUT",
          "path": "/artworks/:id/approve",
          "input": "",
          "output": "AdminActionMessage",
          "middleware": [
            "RequireAdmin"
          ]
        },
        {
          "name": "RejectArtwork",
          "description": "Reject an artwork",
          "method": "PUT",
          "path": "/artworks/:id/reject",
          "input": "",
          "output": "AdminActionMessage",
          "middleware": [
            "RequireAdmin"
          ]
        }
      ]
    },
    {
      "name": "Artworks",
      "description": "Artwork browsing and management",
      "prefix": "/api/artworks",
      "actions": [
        {
          "name": "GetArtworks",
          "description": "Get artworks with optional filtering and pagination",
          "method": "GET",
          "path": "/",
          "input": "",
          "output": "PagedArtwork",
          "query": "ArtworkListQuery",
          "middleware": []
        },
        {
          "name": "GetArtworkById",
          "description": "Get detailed information for one artwork",
          "method": "GET",
          "path": "/:id",
          "input": "",
          "output": "ArtworkDetail",
          "middleware": []
        },
        {
          "name": "GetArtworksByArtist",
          "description": "Get paged artworks for one artist",
          "method": "GET",
          "path": "/artist/:artistId",
          "input": "",
          "output": "PagedArtwork",
          "query": "PaginationQuery",
          "middleware": []
        },
        {
          "name": "CreateArtwork",
          "description": "Create a new artwork (Artist role)",
          "method": "POST",
          "path": "/",
          "input": "CreateArtworkInput",
          "output": "Artwork",
          "middleware": [
            "RequireArtist"
          ]
        },
        {
          "name": "UpdateArtwork",
          "description": "Update an owned artwork (Artist role)",
          "method": "PUT",
          "path": "/:id",
          "input": "CreateArtworkInput",
          "output": "Artwork",
          "middleware": [
            "RequireArtist"
          ]
        },
        {
          "name": "DeleteArtwork",
          "description": "Delete an owned artwork (Artist role)",
          "method": "DELETE",
          "path": "/:id",
          "input": "",
          "output": "AdminActionMessage",
          "middleware": [
            "RequireArtist"
          ]
        },
        {
          "name": "ExtendAuctionTime",
          "description": "Extend auction end time (Artist role)",
          "method": "PUT",
          "path": "/:id/extend",
          "input": "ExtendAuctionTimeInput",
          "output": "Artwork",
          "middleware": [
            "RequireArtist"
          ]
        }
      ]
    },
    {
      "name": "Auth",
      "description": "Authentication and session management",
      "prefix": "/api/auth",
      "actions": [
        {
          "name": "Login",
          "description": "Log in with credentials",
          "method": "POST",
          "path": "/login",
          "input": "LoginInput",
          "output": "AuthToken",
          "middleware": [
            "RateLimit"
          ]
        },
        {
          "name": "Register",
          "description": "Register a new account",
          "method": "POST",
          "path": "/register",
          "input": "RegisterInput",
          "output": "AuthToken",
          "middleware": [
            "RateLimit"
          ]
        },
        {
          "name": "GetMe",
          "description": "Get the currently authenticated user",
          "method": "GET",
          "path": "/me",
          "input": "",
          "output": "User",
          "middleware": [
            "RequireAuth"
          ]
        },
        {
          "name": "Logout",
          "description": "Log out and invalidate session",
          "method": "POST",
          "path": "/logout",
          "input": "",
          "output": "SuccessMessage",
          "middleware": [
            "RequireAuth"
          ]
        }
      ]
    },
    {
      "name": "Users",
      "description": "User management",
      "prefix": "/api/users",
      "actions": [
        {
          "name": "ListUsers",
          "description": "List all users with optional filters",
          "method": "GET",
          "path": "/",
          "input": "",
          "output": "User",
          "outputArray": true,
          "query": "ListQuery",
          "middleware": []
        },
        {
          "name": "GetUser",
          "description": "Get a single user by ID",
          "method": "GET",
          "path": "/:id",
          "input": "",
          "output": "User",
          "middleware": []
        },
        {
          "name": "CreateUser",
          "description": "Create a new user",
          "method": "POST",
          "path": "/",
          "input": "CreateUserInput",
          "output": "User",
          "middleware": []
        },
        {
          "name": "UpdateUser",
          "description": "Update an existing user",
          "method": "PUT",
          "path": "/:id",
          "input": "UpdateUserInput",
          "output": "User",
          "middleware": []
        },
        {
          "name": "DeleteUser",
          "description": "Delete a user",
          "method": "DELETE",
          "path": "/:id",
          "input": "",
          "output": "SuccessMessage",
          "middleware": []
        }
      ]
    }
  ],
  "models": [
    {
      "name": "PendingArtist",
      "description": "Artist account waiting for admin approval",
      "fields": [
        {
          "name": "id",
          "type": "uuid"
        },
        {
          "name": "username",
          "type": "string"
        },
        {
          "name": "email",
          "type": "string"
        },
        {
          "name": "createdAt",
          "type": "datetime"
        }
      ]
    },
    {
      "name": "PendingArtwork",
      "description": "Artwork waiting for admin approval",
      "fields": [
        {
          "name": "id",
          "type": "uuid"
        },
        {
          "name": "title",
          "type": "string"
        },
        {
          "name": "description",
          "type": "string"
        },
        {
          "name": "initialPrice",
          "type": "float"
        },
        {
          "name": "artistName",
          "type": "string"
        },
        {
          "name": "createdAt",
          "type": "datetime"
        }
      ]
    },
    {
      "name": "AdminActionMessage",
      "description": "Message returned after approve/reject actions",
      "fields": [
        {
          "name": "message",
          "type": "string"
        }
      ]
    },
    {
      "name": "Artwork",
      "description": "Lightweight artwork card",
      "fields": [
        {
          "name": "id",
          "type": "uuid"
        },
        {
          "name": "title",
          "type": "string"
        },
        {
          "name": "artistName",
          "type": "string"
        },
        {
          "name": "initialPrice",
          "type": "float"
        },
        {
          "name": "currentBid",
          "type": "float"
        },
        {
          "name": "auctionEndTime",
          "type": "datetime"
        },
        {
          "name": "status",
          "type": "string"
        },
        {
          "name": "imageUrl",
          "type": "string"
        }
      ]
    },
    {
      "name": "ArtworkDetail",
      "description": "Detailed artwork payload",
      "fields": [
        {
          "name": "id",
          "type": "uuid"
        },
        {
          "name": "title",
          "type": "string"
        },
        {
          "name": "description",
          "type": "string"
        },
        {
          "name": "artistName",
          "type": "string"
        },
        {
          "name": "artistId",
          "type": "uuid"
        },
        {
          "name": "initialPrice",
          "type": "float"
        },
        {
          "name": "buyNowPrice",
          "type": "float",
          "optional": true
        },
        {
          "name": "currentBid",
          "type": "float"
        },
        {
          "name": "auctionStartTime",
          "type": "datetime"
        },
        {
          "name": "auctionEndTime",
          "type": "datetime"
        },
        {
          "name": "status",
          "type": "string"
        },
        {
          "name": "categoryName",
          "type": "string"
        },
        {
          "name": "tags",
          "type": "string",
          "isArray": true
        },
        {
          "name": "totalBids",
          "type": "int"
        },
        {
          "name": "imageUrl",
          "type": "string"
        },
        {
          "name": "createdAt",
          "type": "datetime"
        }
      ]
    },
    {
      "name": "CreateArtworkInput",
      "description": "Payload used for create and update artwork",
      "fields": [
        {
          "name": "title",
          "type": "string"
        },
        {
          "name": "description",
          "type": "string"
        },
        {
          "name": "initialPrice",
          "type": "float"
        },
        {
          "name": "buyNowPrice",
          "type": "float",
          "optional": true
        },
        {
          "name": "auctionStartTime",
          "type": "datetime"
        },
        {
          "name": "auctionEndTime",
          "type": "datetime"
        },
        {
          "name": "categoryId",
          "type": "uuid"
        },
        {
          "name": "tags",
          "type": "string",
          "isArray": true
        },
        {
          "name": "imageUrl",
          "type": "string"
        }
      ]
    },
    {
      "name": "ExtendAuctionTimeInput",
      "description": "Payload used to extend auction end time",
      "fields": [
        {
          "name": "newEndTime",
          "type": "datetime"
        }
      ]
    },
    {
      "name": "ArtworkListQuery",
      "description": "Filters for the public artworks list",
      "fields": [
        {
          "name": "pageNumber",
          "type": "int",
          "optional": true
        },
        {
          "name": "pageSize",
          "type": "int",
          "optional": true
        },
        {
          "name": "artistName",
          "type": "string",
          "optional": true
        },
        {
          "name": "categoryName",
          "type": "string",
          "optional": true
        },
        {
          "name": "tagName",
          "type": "string",
          "optional": true
        },
        {
          "name": "status",
          "type": "string",
          "optional": true
        }
      ]
    },
    {
      "name": "PaginationQuery",
      "description": "Basic pagination query",
      "fields": [
        {
          "name": "pageNumber",
          "type": "int",
          "optional": true
        },
        {
          "name": "pageSize",
          "type": "int",
          "optional": true
        }
      ]
    },
    {
      "name": "PagedArtwork",
      "description": "Paged list response for artworks",
      "fields": [
        {
          "name": "items",
          "type": "Artwork",
          "isArray": true
        },
        {
          "name": "totalCount",
          "type": "int"
        },
        {
          "name": "pageNumber",
          "type": "int"
        },
        {
          "name": "pageSize",
          "type": "int"
        },
        {
          "name": "totalPages",
          "type": "int"
        },
        {
          "name": "hasNextPage",
          "type": "bool"
        },
        {
          "name": "hasPreviousPage",
          "type": "bool"
        }
      ]
    },
    {
      "name": "ErrorMessage",
      "description": "Error response payload",
      "fields": [
        {
          "name": "error",
          "type": "string"
        }
      ]
    },
    {
      "name": "User",
      "description": "A platform user",
      "fields": [
        {
          "name": "id",
          "type": "uuid"
        },
        {
          "name": "email",
          "type": "string"
        },
        {
          "name": "name",
          "type": "string"
        },
        {
          "name": "bio",
          "type": "string",
          "optional": true
        },
        {
          "name": "role",
          "type": "UserRole"
        },
        {
          "name": "verified",
          "type": "bool",
          "default": "false"
        },
        {
          "name": "createdAt",
          "type": "datetime"
        }
      ]
    },
    {
      "name": "CreateUserInput",
      "description": "Data required to create a new user",
      "fields": [
        {
          "name": "email",
          "type": "string"
        },
        {
          "name": "name",
          "type": "string"
        },
        {
          "name": "password",
          "type": "string"
        }
      ]
    },
    {
      "name": "UpdateUserInput",
      "description": "Fields that can be updated on a user",
      "fields": [
        {
          "name": "name",
          "type": "string",
          "optional": true
        },
        {
          "name": "bio",
          "type": "string",
          "optional": true
        },
        {
          "name": "role",
          "type": "UserRole",
          "optional": true
        }
      ]
    },
    {
      "name": "LoginInput",
      "description": "Credentials for user login",
      "fields": [
        {
          "name": "email",
          "type": "string"
        },
        {
          "name": "password",
          "type": "string"
        }
      ]
    },
    {
      "name": "RegisterInput",
      "description": "Data for new account registration",
      "fields": [
        {
          "name": "email",
          "type": "string"
        },
        {
          "name": "name",
          "type": "string"
        },
        {
          "name": "password",
          "type": "string"
        }
      ]
    },
    {
      "name": "AuthToken",
      "description": "Token returned after successful authentication",
      "fields": [
        {
          "name": "token",
          "type": "string"
        },
        {
          "name": "user",
          "type": "User"
        }
      ]
    },
    {
      "name": "SuccessMessage",
      "description": "Generic success response",
      "fields": [
        {
          "name": "success",
          "type": "bool"
        },
        {
          "name": "message",
          "type": "string",
          "optional": true
        }
      ]
    },
    {
      "name": "ListQuery",
      "description": "Common query parameters for list endpoints",
      "fields": [
        {
          "name": "search",
          "type": "string",
          "optional": true
        },
        {
          "name": "limit",
          "type": "int",
          "optional": true
        },
        {
          "name": "offset",
          "type": "int",
          "optional": true
        }
      ]
    }
  ]
}